{
  "name": "Mitglied",
  "type": "object",
  "properties": {
    "org_id": {
      "type": "string",
      "description": "Referenz zur Organisation"
    },
    "user_id": {
      "type": "string",
      "description": "Referenz zum User"
    },
    "rolle": {
      "type": "string",
      "enum": [
        "Band Manager",
        "Musiker"
      ],
      "description": "Rolle in der Organisation"
    },
    "status": {
      "type": "string",
      "enum": [
        "aktiv",
        "eingeladen",
        "gesperrt"
      ],
      "default": "aktiv",
      "description": "Status des Mitglieds"
    },
    "musiker_id": {
      "type": "string",
      "description": "Verkn\u00fcpfung zum Musiker-Profil (wenn Rolle=Musiker)"
    }
  },
  "required": [
    "org_id",
    "user_id",
    "rolle"
  ]
}